{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python Debugger: Streamlit (backup_app.py)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/Black_Pioneers_Studio/backup_app.py",
        "--server.port",
        "8501"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/Black_Pioneers_Studio",
      "justMyCode": true
    },
    {
      "name": "Python Debugger: Streamlit (app.py)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/Black_Pioneers_Studio/app.py",
        "--server.port",
        "8501"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/Black_Pioneers_Studio",
      "justMyCode": true,
      "preLaunchTask": "Initialize app.py database and output"
    }
  ]
}
