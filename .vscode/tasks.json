{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🤖 Start Android Emulator (BlackPioneer_API33)",
      "type": "shell",
      "command": "/Users/za914/.buildozer/android/platform/android-sdk/emulator/emulator",
      "args": ["-avd", "BlackPioneer_API33", "-no-snapshot-load"],
      "isBackground": true,
      "options": {
        "env": {
          "ANDROID_SDK_ROOT": "/Users/za914/.buildozer/android/platform/android-sdk",
          "ANDROID_HOME": "/Users/za914/.buildozer/android/platform/android-sdk"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "android"
      }
    },
    {
      "label": "📲 Install APK on Emulator",
      "type": "shell",
      "command": "/Users/za914/Downloads/platform-tools/adb",
      "args": ["install", "-r", "${workspaceFolder}/bin/${input:apkFile}"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "android"
      }
    },
    {
      "label": "🔨 Build Android APK (Buildozer)",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "export PATH=$HOME/.venv312/bin:$PATH && export BUILDOZER_BUILD_DIR=${TMPDIR%/}/black-pioneers-studio-buildozer && export SSL_CERT_FILE=$($HOME/.venv312/bin/python -c 'import certifi; print(certifi.where())') && export REQUESTS_CA_BUNDLE=$SSL_CERT_FILE && $HOME/.venv312/bin/buildozer -v android debug"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "android"
      }
    },
    {
      "label": "Initialize app.py database and output",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-c",
        "from app import initialize_database, PIONEERS_OUTPUT_DIR; initialize_database(); PIONEERS_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "apkFile",
      "type": "promptString",
      "description": "APK filename (in bin/ folder)",
      "default": "blackpioneers-0.1-arm64-v8a-debug.apk"
    }
  ]
}
